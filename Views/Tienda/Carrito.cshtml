@model List<LOGIN.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4">
    <div class="card card-modern">
        <div class="card-header bg-white border-bottom-0 pt-4">
            <h2 class="h3 fw-bold">
                <i class="bi bi-cart3 text-primary"></i> Mi Carrito
            </h2>
        </div>
        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x fs-1 text-muted"></i>
                    <h4 class="mt-3">Tu carrito está vacío</h4>
                    <a asp-action="Index" class="btn btn-gradient mt-3">
                        <i class="bi bi-shop"></i> Seguir comprando
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <i class="bi bi-box-seam fs-2 text-secondary"></i>
                                            <div>
                                                <h6 class="mb-0 fw-bold">@item.Producto?.Nombre</h6>
                                                <small class="text-muted">Stock: @item.Producto?.Cantidad</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="input-group" style="width: 120px; margin: 0 auto;">
                                            <button class="btn btn-outline-secondary btn-minus" data-id="@item.Id">-</button>
                                            <input type="number" class="form-control text-center cantidad-input" data-id="@item.Id" value="@item.Cantidad" min="1" max="@item.Producto?.Cantidad" />
                                            <button class="btn btn-outline-secondary btn-plus" data-id="@item.Id">+</button>
                                        </div>
                                    </td>
                                    <td class="text-end">@item.Producto?.Precio.ToString("C")</td>
                                    <td class="text-end fw-bold subtotal" data-id="@item.Id">
                                        @((item.Cantidad * (item.Producto?.Precio ?? 0)).ToString("C"))
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger btn-remove" data-id="@item.Id">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top">
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5">Total:</td>
                                <td class="text-end fw-bold fs-4 text-primary" id="total">
                                    @ViewBag.Total.ToString("C")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                        <i class="bi bi-arrow-left"></i> Seguir comprando
                    </a>
                    <a asp-action="Checkout" class="btn btn-gradient rounded-pill px-4">
                        Proceder al pago <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function actualizarCarrito() {
    location.reload();
    }

    $(document).ready(function() {
    function actualizarItem(itemId, nuevaCantidad) {
    $.post('/Tienda/ActualizarCantidad', { itemId: itemId, cantidad: nuevaCantidad })
    .done(function(response) {
    if (response.success) {
    if (response.itemRemoved) {
    actualizarCarrito();
    } else {
    $(`.subtotal[data-id='${itemId}']`).text('$' + response.subtotal.toFixed(2));
    $('#total').text('$' + response.total.toFixed(2));
    }
    } else if (response.message) {
    alert(response.message);
    actualizarCarrito();
    }
    });
    }

    $('.btn-plus').click(function() {
    var itemId = $(this).data('id');
    var input = $(`.cantidad-input[data-id='${itemId}']`);
    var nuevaCantidad = parseInt(input.val()) + 1;
    actualizarItem(itemId, nuevaCantidad);
    });

    $('.btn-minus').click(function() {
    var itemId = $(this).data('id');
    var input = $(`.cantidad-input[data-id='${itemId}']`);
    var nuevaCantidad = parseInt(input.val()) - 1;
    actualizarItem(itemId, nuevaCantidad);
    });

    $('.cantidad-input').change(function() {
    var itemId = $(this).data('id');
    var nuevaCantidad = parseInt($(this).val());
    if (nuevaCantidad > 0) {
    actualizarItem(itemId, nuevaCantidad);
    }
    });

    $('.btn-remove').click(function() {
    var itemId = $(this).data('id');
    if (confirm('¿Eliminar este producto del carrito?')) {
    actualizarItem(itemId, 0);
    }
    });
    });
</script>
