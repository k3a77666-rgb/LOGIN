@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-4">
    <div class="card card-custom">
        <div class="card-header bg-white border-bottom-0 pt-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="h3 mb-1 fw-bold">
                        <i class="bi bi-box-seam text-primary me-2"></i>Mi Inventario
                    </h2>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-database"></i> Total: @Model.Count() productos
                    </p>
                </div>
                <a asp-action="Create" class="btn btn-custom-primary">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Producto
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No hay productos</h4>
                    <p class="text-muted">¡Comienza agregando tu primer producto!</p>
                    <a asp-action="Create" class="btn btn-custom-primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i>Agregar Producto
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle table-modern">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">ID</th>
                                <th class="border-0">Nombre</th>
                                <th class="border-0 d-none d-md-table-cell">Descripción</th>
                                <th class="border-0 text-center">Stock</th>
                                <th class="border-0 text-end">Precio</th>
                                <th class="border-0 text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-secondary fw-bold">#@item.Id</td>
                                    <td class="fw-semibold">@item.Nombre</td>
                                    <td class="text-muted small d-none d-md-table-cell">
                                        @(item.Descripcion?.Length > 60 ? item.Descripcion.Substring(0, 60) + "..." : item.Descripcion ?? "—")
                                    </td>
                                    <td class="text-center">
                                        @if (item.Cantidad == 0)
                                        {
                                            <span class="badge-stock" style="background: #fee2e2; color: #dc2626;">
                                                <i class="bi bi-x-circle me-1"></i>Sin stock
                                            </span>
                                        }
                                        else if (item.Cantidad < 5)
                                        {
                                            <span class="badge-stock" style="background: #fed7aa; color: #ea580c;">
                                                <i class="bi bi-exclamation-triangle me-1"></i>@item.Cantidad uds
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-stock" style="background: #dcfce7; color: #16a34a;">
                                                <i class="bi bi-check-circle me-1"></i>@item.Cantidad uds
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold fs-5" style="color: #667eea;">
                                        @item.Precio.ToString("C")
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info rounded-start-3" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-end-3" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

