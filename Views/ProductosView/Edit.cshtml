@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-custom">
                <div class="card-header bg-white border-bottom-0 pt-4">
                    <div class="text-center">
                        <i class="bi bi-pencil-square fs-1" style="color: #f59e0b;"></i>
                        <h2 class="h3 mt-2 fw-bold">Editar Producto</h2>
                        <p class="text-muted small">Modifica los datos del producto</p>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="FechaRegistro" />

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold">
                                <i class="bi bi-tag me-1"></i>Nombre *
                            </label>
                            <input asp-for="Nombre" class="form-control rounded-3" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-semibold">
                                <i class="bi bi-file-text me-1"></i>Descripción
                            </label>
                            <textarea asp-for="Descripcion" class="form-control rounded-3" rows="3"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Cantidad" class="form-label fw-semibold">
                                    <i class="bi bi-box me-1"></i>Cantidad *
                                </label>
                                <input asp-for="Cantidad" class="form-control rounded-3" type="number" min="0" />
                                <span asp-validation-for="Cantidad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Precio" class="form-label fw-semibold">
                                    <i class="bi bi-currency-dollar me-1"></i>Precio *
                                </label>
                                <input asp-for="Precio" class="form-control rounded-3" type="number" step="0.01" min="0.01" />
                                <span asp-validation-for="Precio" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                                <i class="bi bi-arrow-left me-1"></i>Volver
                            </a>
                            <button type="submit" class="btn btn-warning rounded-pill px-4">
                                <i class="bi bi-save me-1"></i>Actualizar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}