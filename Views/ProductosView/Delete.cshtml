@model LOGIN.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-custom">
                <div class="card-header bg-white border-bottom-0 pt-4">
                    <div class="text-center">
                        <i class="bi bi-exclamation-triangle-fill fs-1" style="color: #dc2626;"></i>
                        <h2 class="h3 mt-2 fw-bold">Confirmar eliminación</h2>
                        <p class="text-danger small">⚠️ Esta acción no se puede deshacer</p>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning rounded-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>¿Estás seguro?</strong> El producto se eliminará permanentemente.
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <dl class="row mb-0 small">
                            <dt class="col-sm-4 fw-semibold">@Html.DisplayNameFor(model => model.Nombre)</dt>
                            <dd class="col-sm-8 text-secondary">@Html.DisplayFor(model => model.Nombre)</dd>

                            <dt class="col-sm-4 fw-semibold">@Html.DisplayNameFor(model => model.Descripcion)</dt>
                            <dd class="col-sm-8 text-secondary">@Html.DisplayFor(model => model.Descripcion)</dd>

                            <dt class="col-sm-4 fw-semibold">@Html.DisplayNameFor(model => model.Cantidad)</dt>
                            <dd class="col-sm-8 text-secondary">@Html.DisplayFor(model => model.Cantidad)</dd>

                            <dt class="col-sm-4 fw-semibold">@Html.DisplayNameFor(model => model.Precio)</dt>
                            <dd class="col-sm-8 text-secondary fw-bold" style="color: #667eea;">@Html.DisplayFor(model => model.Precio)</dd>
                        </dl>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger rounded-pill px-4">
                                <i class="bi bi-trash me-1"></i>Sí, eliminar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
