<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi Inventario</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Google Fonts - Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="~/css/site.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-modern">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i>Mi Inventario
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ProductosView" asp-action="Index">
                                    <i class="bi bi-grid-3x3-gap-fill"></i>Productos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                    <i class="bi bi-shop"></i>Tienda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" asp-controller="Reportes" asp-action="Dashboard">
                                    <i class="bi bi-bar-chart-fill"></i>Reportes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i>Cerrar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-primary fw-semibold">
                                    <i class="bi bi-person-circle"></i>
                                    @Context.Session.GetString("UsuarioNombre")
                                </span>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i>Iniciar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn-gradient text-white" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i>Registrarse
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="fade-in">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER ACTUALIZADO -->
    <footer class="footer-modern">
        <div class="container-fluid px-4">
            <div class="row align-items-center">
                <div class="col-md-6 text-start">
                    <small class="text-muted">
                        <i class="bi bi-c-circle"></i> @DateTime.Now.Year - MiInventario
                    </small>
                </div>
                <div class="col-md-6 text-end">
                    <small>
                        <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none me-3">
                            <i class="bi bi-shield-check"></i> Privacidad
                        </a>
                        <a asp-controller="Home" asp-action="Support" class="text-muted text-decoration-none">
                            <i class="bi bi-headset"></i> Soporte
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>