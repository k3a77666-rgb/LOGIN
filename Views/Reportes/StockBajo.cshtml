@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Stock Bajo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="bi bi-exclamation-triangle text-danger"></i> Stock Bajo
            </h2>
            <p class="text-muted">Productos que necesitan reposición</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-gradient">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card-modern text-center p-5">
            <i class="bi bi-check-circle-fill text-success fs-1"></i>
            <h4 class="mt-3">¡Todos los productos tienen stock suficiente!</h4>
            <p class="text-muted">No hay productos con stock bajo</p>
        </div>
    }
    else
    {
        <div class="card-modern p-4">
            <div class="table-responsive">
                <table class="table table-modern">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th class="text-center">Stock</th>
                            <th class="text-end">Precio</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-secondary">#@item.Id</td>
                                <td class="fw-semibold">@item.Nombre</td>
                                <td class="text-muted small">@item.Descripcion</td>
                                <td class="text-center">
                                    <span class="badge-modern badge-danger">
                                        <i class="bi bi-exclamation-triangle"></i> @item.Cantidad uds
                                    </span>
                                </td>
                                <td class="text-end fw-bold">@item.Precio.ToString("C")</td>
                                <td>
                                    <a asp-controller="ProductosView" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-gradient btn-sm">
                                        <i class="bi bi-pencil"></i> Reponer
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>