@model IEnumerable<LOGIN.Models.Pedido>

@{
    ViewData["Title"] = "Reporte de Compras";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="bi bi-cart-check text-success"></i> Ventas
            </h2>
            <p class="text-muted">Historial de pedidos realizados</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-gradient">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <!-- Estadísticas -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color: #48bb78;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Total Ventas</div>
                        <div class="stat-number">@ViewBag.TotalVentas.ToString("C")</div>
                    </div>
                    <div class="stat-icon text-success">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color: #63b3ed;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Total Pedidos</div>
                        <div class="stat-number">@ViewBag.TotalPedidos</div>
                    </div>
                    <div class="stat-icon text-info">
                        <i class="bi bi-receipt"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left-color: #ed8936;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">Pendientes</div>
                        <div class="stat-number text-warning">@ViewBag.PedidosPendientes</div>
                    </div>
                    <div class="stat-icon text-warning">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card-modern p-4">
        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th>Pedido #</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Total</th>
                        <th>Detalles</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@pedido.Id</td>
                            <td>@pedido.Usuario?.Nombre</td>
                            <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @{
                                    var estadoClass = pedido.Estado switch
                                    {
                                        EstadoPedido.Confirmado => "badge-success",
                                        EstadoPedido.Pendiente => "badge-warning",
                                        EstadoPedido.Enviado => "badge-info",
                                        EstadoPedido.Entregado => "badge-success",
                                        EstadoPedido.Cancelado => "badge-danger",
                                        _ => "badge-secondary"
                                    };
                                }
                                <span class="badge-modern @estadoClass">@pedido.Estado</span>
                            </td>
                            <td class="text-end fw-bold text-primary">@pedido.Total.ToString("C")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-gradient" type="button" data-bs-toggle="collapse" data-bs-target="#detalles@pedido.Id">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="6" class="p-0">
                                <div class="collapse" id="detalles@pedido.Id">
                                    <div class="p-3 bg-light">
                                        <h6 class="fw-bold">Detalles del Pedido #@pedido.Id</h6>
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Producto</th>
                                                    <th>Cantidad</th>
                                                    <th>Precio Unitario</th>
                                                    <th>Subtotal</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var detalle in pedido.Detalles!)
                                                {
                                                    <tr>
                                                        <td>@detalle.Producto?.Nombre</td>
                                                        <td>@detalle.Cantidad</td>
                                                        <td>@detalle.PrecioUnitario.ToString("C")</td>
                                                        <td>@detalle.Subtotal.ToString("C")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>