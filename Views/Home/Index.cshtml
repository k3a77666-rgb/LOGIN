@{
    ViewData["Title"] = "Inicio";
    var usuarioNombre = ViewBag.UsuarioNombre ?? "Usuario";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Tarjeta de Bienvenida -->
            <div class="card-modern p-5 text-center">
                <div class="mb-4">
                    <div class="avatar-circle mx-auto">
                        <i class="bi bi-person-fill fs-1 text-white"></i>
                    </div>
                </div>

                <h1 class="display-4 fw-bold">
                    ¡Bienvenido, <span class="text-primary">@usuarioNombre</span>!
                </h1>
                <p class="text-muted fs-5 mt-3">
                    Has iniciado sesión correctamente. Desde aquí puedes administrar el catálogo de inventarios o gestionar tu sesión actual.
                </p>

                <hr class="my-5" />

                <!-- Cards de Acción -->
                <div class="row g-4">
                    <!-- Gestión de Productos -->
                    <div class="col-md-6">
                        <div class="action-card text-start p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="action-icon bg-primary">
                                    <i class="bi bi-box-seam text-white"></i>
                                </div>
                                <h5 class="fw-bold mb-0 ms-3">Gestión de Productos</h5>
                            </div>
                            <p class="text-muted small mb-3">
                                Administra e inspecciona el stock de tu inventario de forma centralizada.
                            </p>
                            <a asp-controller="ProductosView" asp-action="Index" class="btn btn-gradient btn-sm">
                                Ver Productos <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Mi Cuenta -->
                    <div class="col-md-6">
                        <div class="action-card text-start p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="action-icon bg-danger">
                                    <i class="bi bi-person-lock text-white"></i>
                                </div>
                                <h5 class="fw-bold mb-0 ms-3">Mi Cuenta</h5>
                            </div>
                            <p class="text-muted small mb-3">
                                Gestiona tus credenciales de acceso y mantén tu cuenta protegida.
                            </p>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Estadísticas rápidas -->
                <div class="row g-3 mt-4">
                    <div class="col-4">
                        <div class="stat-mini">
                            <span class="stat-mini-number">@ViewBag.TotalProductos</span>
                            <span class="stat-mini-label">Productos</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini">
                            <span class="stat-mini-number">@ViewBag.TotalUsuarios</span>
                            <span class="stat-mini-label">Usuarios</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini">
                            <span class="stat-mini-number">@ViewBag.TotalPedidos</span>
                            <span class="stat-mini-label">Pedidos</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Estilos adicionales -->
<style>
    .avatar-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
    }

    .action-card {
        background: #f8fafc;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        height: 100%;
    }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
            border-color: var(--primary-color);
        }

    .action-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .action-icon.bg-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .action-icon.bg-danger {
            background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
        }

    .stat-mini {
        text-align: center;
        padding: 0.75rem;
        background: #f8fafc;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
    }

    .stat-mini-number {
        display: block;
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a202c;
    }

    .stat-mini-label {
        display: block;
        font-size: 0.75rem;
        color: #718096;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>